{
  "_comment": "Add a new site by copying any block and changing the keys. Fields:",
  "_fields": {
    "name":           "Display name shown in the popup",
    "domains":        "List of hostname substrings that identify this site",
    "searchShadowDom":"Optional – set true if buttons live inside a shadow root",
    "buttons": {
      "label":    "Human-readable name shown in the popup",
      "selector": "CSS selector for the button element",
      "delayMs":  "Optional – wait this many ms after the button appears before clicking"
    }
  },

  "netflix": {
    "name": "Netflix",
    "domains": ["netflix.com"],
    "buttons": [
      { "label": "Skip Intro",   "selector": "button[data-uia=\"player-skip-intro\"]" },
      { "label": "Skip Recap",   "selector": "button[data-uia=\"player-skip-recap\"]" },
      { "label": "Next Episode", "selector": "button[data-uia=\"player-skip-seamless-button\"]" }
    ]
  },

  "disneyPlus": {
    "name": "Disney+",
    "domains": ["disneyplus.com"],
    "buttons": [
      { "label": "Skip Recap",        "selector": "button.skip__button[aria-label=\"SKIP RECAP\"]" },
      { "label": "Skip Intro",        "selector": "button.skip__button[aria-label=\"SKIP INTRO\"]" },
      { "label": "Next Episode",      "selector": "button.skip__button:not([aria-label])" },
      { "label": "Next Episode (Alt)","selector": "button[data-testid=\"icon-restart\"]" }
    ]
  },

  "hulu": {
    "name": "Hulu",
    "domains": ["hulu.com"],
    "buttons": [
      { "label": "Skip Intro / Recap", "selector": "button[data-automationid=\"player-skip-button\"]" },
      { "label": "Next Episode",       "selector": "button[data-testid=\"next-episode-button\"]" }
    ]
  },

  "crunchyroll": {
    "name": "Crunchyroll",
    "domains": ["crunchyroll.com", "static.crunchyroll.com"],
    "buttons": [
      { "label": "Skip Intro / Recap", "selector": "[data-testid=\"skipIntroText\"]" },
      { "label": "Next Episode",       "selector": "[data-testid=\"nextEpisodeButton\"]" }
    ]
  },

  "paramountPlus": {
    "name": "Paramount+",
    "domains": ["paramountplus.com"],
    "buttons": [
      { "label": "Skip Intro",   "selector": "button.skip-button" },
      { "label": "Next Episode", "selector": "button.play-button" }
    ]
  },

  "amazonPrime": {
    "name": "Amazon Prime Video",
    "domains": ["amazon.com", "primevideo.com"],
    "buttons": [
      { "label": "Skip Intro",   "selector": "button[class*=\"atvwebplayersdk-skipelement-button\"]" },
      { "label": "Next Episode", "selector": "div[class*=\"atvwebplayersdk-nextupcard-button\"]" }
    ]
  },

  "max": {
    "name": "Max (HBO)",
    "domains": ["max.com"],
    "buttons": [
      { "label": "Skip Intro",   "selector": "button[data-testid=\"player-skip-intro-button\"]" },
      { "label": "Skip Recap",   "selector": "button[data-testid=\"player-skip-recap-button\"]" },
      { "label": "Next Episode", "selector": "button[data-testid=\"player-skip-credit-button\"]" }
    ]
  },

  "peacock": {
    "name": "Peacock",
    "domains": ["peacocktv.com"],
    "buttons": [
      { "label": "Skip Intro",   "selector": "[class*='SkipButton']" },
      { "label": "Next Episode", "selector": "[class*='NextEpisodeButton']" }
    ]
  },

  "appleTvPlus": {
    "name": "Apple TV+",
    "domains": ["tv.apple.com"],
    "searchShadowDom": true,
    "buttons": [
      { "label": "Skip Intro",   "selector": "button[data-testid=\"skip-button\"]", "delayMs": 500 },
      { "label": "Next Episode", "selector": "button[data-testid=\"up-next-button\"]" }
    ]
  },

  "tubi": {
    "name": "Tubi",
    "domains": ["tubitv.com"],
    "buttons": [
      { "label": "Skip Intro",   "selector": "[data-ui-navigable=\"skip-intro-button\"]" },
      { "label": "Next Episode", "selector": "[class*='skip-credits']" }
    ]
  }
}
